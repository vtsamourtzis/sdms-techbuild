<%- include('partials/head', { authPage: true }) %>
<div class="auth-center">
  <div class="auth-box">
    <div class="logo-row">
      <div class="badge-s" style="background:var(--accent);color:#fff;width:32px;height:32px;border-radius:8px;display:grid;place-items:center;font-weight:800;font-size:.9rem;flex-shrink:0">S</div>
      <div>
        <div style="font-weight:700;font-size:1rem">SDMS Portal</div>
        <div style="font-size:.75rem;color:var(--muted)">Secure Document Management</div>
      </div>
    </div>
    <h1>Sign in</h1>
    <p class="sub">Enter your credentials. A one-time code will be sent after password verification.</p>

    <%- include('partials/flash') %>

    <form method="POST" action="/login">
      <div class="field">
        <label for="email">Work email</label>
        <input type="email" id="email" name="email" autocomplete="email" required placeholder="you@techbuild.com" />
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required placeholder="••••••••" />
      </div>
      <button type="submit" class="btn btn-primary btn-full" style="margin-top:.4rem">Continue →</button>
    </form>
    <p style="text-align:center;font-size:.82rem;color:var(--muted);margin-top:1.1rem">
      No account? <a href="/register">Register here</a>
    </p>
  </div>
</div>
<%- include('partials/foot') %>
