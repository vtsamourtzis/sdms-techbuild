<% if (flash.error   && flash.error.length)   { %><div class="alert alert-error"><%=   flash.error[0]   %></div><% } %>
<% if (flash.success && flash.success.length) { %><div class="alert alert-success"><%= flash.success[0] %></div><% } %>
<% if (flash.info    && flash.info.length)    { %><div class="alert alert-info"><%=    flash.info[0]    %></div><% } %>
<% if (flash.warn    && flash.warn.length)    { %><div class="alert alert-warn"><%=    flash.warn[0]    %></div><% } %>
